# Copy to .env and adjust for your environment.

# HuggingFace model id for the Quran-tuned ASR model.
ASR_MODEL_NAME=tarteel-ai/whisper-base-ar-quran

# torch device index for the ASR pipeline: -1 = CPU, 0 = first GPU.
ASR_DEVICE=-1

# Quran content API (Quran.com API v4) used to look up verse text by surah:ayah.
QURAN_API_BASE_URL=https://api.quran.com/api/v4

# Set to 1 AFTER the first successful startup (model cached) for fast,
# fully-offline model loading with no HuggingFace network retries.
HF_HUB_OFFLINE=0

# Max accepted audio upload size in bytes (default 10MB).
MAX_UPLOAD_BYTES=10485760

# Comma-separated CORS origins; "*" is fine while there is no web build.
CORS_ALLOW_ORIGINS=*

# ffmpeg is REQUIRED to decode uploaded audio (m4a from phones, mp3, etc).
# Leave as "ffmpeg" if it's on PATH, or set an absolute path to the binary.
FFMPEG_PATH=ffmpeg

# Postgres for progress/mistake persistence. The schema self-initializes at
# startup; the API still runs (without persistence) if the DB is unreachable.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

# Signs auth tokens. REQUIRED: set a long random value, e.g.
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-to-a-long-random-string
